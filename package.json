{
  "private": true,
  "type": "module",
  "name": "playcanvas-template",
  "version": "2.0.0",
  "license": "MIT",
  "browserslist": [
    "baseline 2025"
  ],
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^22.22.0 || >=24.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
