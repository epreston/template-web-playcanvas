    "lint": "eslint --ext .js,.ts --report-unused-disable-directives .",
    "format": "prettier --write \"**/*.[tj]s?(x)\""
  },
  "devDependencies": {
    "@playcanvas/eslint-config": "^2.1.0",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "playcanvas": "^2.17.2"
  }
}
